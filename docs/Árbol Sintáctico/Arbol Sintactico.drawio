        <mxCell id="3ZzosOsCB9qEzDbue6gD-1" value="&lt;div&gt;struct X {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;int a;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;int b;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;float c;&lt;/div&gt;&lt;div&gt;}a, b;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;float x, y;&lt;/div&gt;&lt;div&gt;int m, n;&lt;/div&gt;&lt;div&gt;int c;&lt;/div&gt;&lt;div&gt;int i, j;&lt;/div&gt;&lt;div&gt;float[5][7][3] w;&lt;/div&gt;&lt;div&gt;int z;&lt;/div&gt;&lt;div&gt;int w1;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="284" y="620" width="160" height="230" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-3" value="&lt;b&gt;Árbol parte 1: declaraciones globales.&amp;nbsp;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="213" y="560" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-4" value="&lt;b&gt;Árbol parte 2: función suma&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fillColor=#ffcccc;strokeColor=#36393d;" parent="1" vertex="1">
          <mxGeometry x="1545" y="740" width="225" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-5" value="&lt;div&gt;def int suma(int x, int y){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; w1= 5;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; z = x + y + w1;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; return z;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#ffcccc;strokeColor=#36393d;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="1570" y="800" width="160" height="110" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-12" value="&lt;b&gt;Árbol parte 3a: cabecera de main y sentencias inciales&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fillColor=#ffcc99;strokeColor=#36393d;" parent="1" vertex="1">
          <mxGeometry x="3007.5" y="910" width="385" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-13" value="&lt;div&gt;def int main(){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;a.a= 8;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;a.b= 2;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;a.c = 1.5;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;m= 7;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;n = 15;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;c = suma(m, n);&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#ffcc99;strokeColor=#36393d;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="3100" y="965" width="160" height="135" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-14" value="&lt;b&gt;Árbol parte 3b: los dos bloques de for triplemente anidados de main&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fillColor=#ffff88;strokeColor=#36393d;" parent="1" vertex="1">
          <mxGeometry x="3400" y="1840" width="480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3ZzosOsCB9qEzDbue6gD-15" value="&lt;div&gt;&amp;nbsp; &amp;nbsp;for(i=0; i &amp;lt; 5; i = i+1){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; for(j=0; j&amp;lt;7; j= j+1){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;for(k=0; k &amp;lt;3; k=k+1)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; a[i][j][k]= 0;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;}&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;for(i=0; i &amp;lt; 5; i = i+1){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; for(j=0; j&amp;lt;7; j= j+1){&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;for(k=0; k &amp;lt;3; k=k+1)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;b[i][j][k]= b[i][j][k] + 3;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;}&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;}&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;return 0;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fillColor=#ffff88;strokeColor=#36393d;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="3540" y="1910" width="220" height="260" as="geometry" />
        </mxCell>
